# Environment variables for claude-safety-hooks
# Copy to your shell rc, a .env loader, or your CI secret store.
# NEVER commit a populated .env — only this .example file.

# ─── REQUIRED: Production passkey hashes ──────────────────────────────
# Generate each hash by running:
#   echo -n "<your-chosen-passkey>" | sha256sum
# Then paste the 64-char hex digest below. You can reuse the same passkey
# across all three guardians, or pick different ones per service.

SF_PROD_PASSKEY_HASH=replace-with-64-char-sha256-hex
DB_PROD_PASSKEY_HASH=replace-with-64-char-sha256-hex
AWS_PROD_PASSKEY_HASH=replace-with-64-char-sha256-hex

# ─── REQUIRED: AWS production account ────────────────────────────────
# Your 12-digit production AWS account ID.
PROD_ACCOUNT_ID=

# ─── OPTIONAL: AWS non-production accounts ───────────────────────────
# If you set these, the guardian skips entirely when calls target them.
# If unset, the guardian falls through to whitelist enforcement.
UAT_ACCOUNT_ID=
DEV_ACCOUNT_ID=
SANDBOX_ACCOUNT_ID=

# ─── OPTIONAL: Salesforce production identifiers ─────────────────────
# Used to detect production targeting in sf/sfdx commands.
# Leave empty to rely solely on `--target-org production` matching.
SF_PROD_USERNAME=
SF_PROD_ORG_ID=

# ─── OPTIONAL: Database name for block messages ──────────────────────
# Shown in DB guardian block messages. Defaults to "<prod>" if unset.
DB_NAME=
